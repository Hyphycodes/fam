# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill it in. See SETUP.md for where each
# value lives in the Supabase / Cloudflare dashboards.
# ---------------------------------------------------------------------------

# --- App ---
NEXT_PUBLIC_APP_NAME=Reel
NEXT_PUBLIC_APP_URL=http://localhost:3000   # swap to your Vercel URL after first deploy

# The first account allowed in, seeded as `owner`. Everyone else is invited from
# inside the app. Without this, nobody can log in.
OWNER_EMAIL=

# --- Supabase (auth + metadata) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare (shared) ---
CLOUDFLARE_ACCOUNT_ID=

# --- Cloudflare Stream (video) ---
CLOUDFLARE_STREAM_API_TOKEN=
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_CODE=

# Optional but recommended — makes videos private (playback needs a short-lived
# signed token instead of being viewable by anyone who guesses the UID).
# Generate both with: npm run stream:signing-key
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_JWK=

# --- Cloudflare R2 (photos + original files) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=reel-media
R2_ENDPOINT=

# --- Later / optional (AI features — NOT needed for v1) ---
ANTHROPIC_API_KEY=
